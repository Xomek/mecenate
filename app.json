{
  "expo": {
    "name": "Mecenate Feed",
    "slug": "mecenate-feed",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mecenate.feed"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.mecenate.feed"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "scheme": "mecenate",
    "extra": {}
  }
}
